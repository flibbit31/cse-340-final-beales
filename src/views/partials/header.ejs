<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>WM Project Management Tool</title>
        <link rel="stylesheet" href="/css/main.css">
        <%- renderStyles() %>
        <%- renderScripts() %>
        <% if (NODE_ENV.includes('dev')) { %>
            <script>
                // set up live reloading on browser
                const host = window.location.hostname;
                const currentPort = window.location.port;

                const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

                const ws = new WebSocekt(`ws://${host}:${wsPort}`);
                ws.onclose = () => {
                    setTimeout(() => location.reload(), 2000);
                };
            </script>
        <% } %>
    </head>
    <body>
        <header>
        <% 
            const messages = flash();
            const hasMessages = Object.values(messages).some(arr => arr.length > 0);
        %>
        <% if (hasMessages) { %>
            <div class="flash-messages">
                <% Object.keys(messages).forEach(type => { %>
                    <% messages[type].forEach(message => { %>
                        <div class="flash <%= type %>">
                            <%= message %>
                        </div>
                    <% }); %>
                <% }); %>
            </div>
        <% } %>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>

                    <% if (!isLoggedIn) { %>
                        <li><a href="/register">Register</a></li>
                        <li><a href="/login">Login</a></li>
                    <% } %>

                    <% if (roleName) { %>
                        <li><a href="/projects">Projects</a></li>
                    <% } %>

                    <% if (isLoggedIn) { %>
                        <li><a href="/logout">Logout</a></li>
                    <% } %>
                    
                </ul>
            </nav>
        </header>
